  "plugins": {
    "google-analytics": {
      "names": [
        "google-analytics-for-wordpress",
        "googleanalytics",
        "ga-google-analytics",
        "gtm4wp",
        "google-tag-manager"
      ],
      "label": "Google Analytics",
      "category": "analytics",
      "cookies": [
        { "name": "_ga",    "duration": "2 ans",    "purpose": "Distingue les utilisateurs et les sessions" },
        { "name": "_gid",   "duration": "24 heures","purpose": "Distingue les utilisateurs" },
        { "name": "_gat",   "duration": "1 minute", "purpose": "Limite le taux de requêtes" },
        { "name": "_ga_*",  "duration": "2 ans",    "purpose": "Maintient l'état de session (GA4)" }
      ],
      "provider": "Google LLC",
      "privacy_url": "https://policies.google.com/privacy"
    },
