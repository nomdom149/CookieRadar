      "cookies": [
        { "name": "_fbp",  "duration": "3 mois",   "purpose": "Identifie les navigateurs pour la publicité Meta" },
        { "name": "_fbc",  "duration": "2 ans",    "purpose": "Stocke le dernier clic publicitaire Facebook" },
        { "name": "fr",    "duration": "3 mois",   "purpose": "Publicité ciblée Facebook" }
      ],
      "provider": "Meta Platforms Inc.",
      "privacy_url": "https://www.facebook.com/privacy/policy"
    },
